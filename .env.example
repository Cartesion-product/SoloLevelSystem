# === Solo Leveling System - Environment Variables ===

# --- App ---
DEBUG=true
SECRET_KEY=change-me-in-production
HOST=0.0.0.0
PORT=8000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/solo_leveling
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=solo_leveling

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=  # Set for proxy/custom endpoint
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat

# --- Embedding ---
# Provider: openai / deepseek / ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# --- Ollama (local models) ---
OLLAMA_BASE_URL=http://localhost:11434
# To use Ollama for embedding:
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSION=768

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- File Upload ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
